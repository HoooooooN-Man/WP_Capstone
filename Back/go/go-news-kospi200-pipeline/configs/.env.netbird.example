# Copy this file to configs/.env for NetBird/VPN-based queue Redis usage.
# 모든 자격증명·IP 는 환경별로 직접 채워 사용. 절대 git 에 커밋하지 말 것.
REDIS_QUEUE_HOST=__VPN_HOST__
REDIS_QUEUE_PORT=6380
REDIS_QUEUE_PASSWORD=__GENERATE_STRONG_PASSWORD__
REDIS_QUEUE_DB=0
REDIS_QUEUE_PROTOCOL=2

RAW_STREAM=news:raw
NORMALIZED_STREAM=news:normalized
BATCH_READY_STREAM=news:batch_ready
RAW_GROUP=matcher-group
NORMALIZED_GROUP=aggregator-group
BATCH_GROUP=writer-group
RAW_CONSUMER=matcher-1
NORMALIZED_CONSUMER=aggregator-1
BATCH_CONSUMER=writer-1
DEDUP_PREFIX=news:dedup
UNIVERSE_PATH=data/universe/current/kospi200.aliases.current.json
SOURCE_POLICY_PATH=data/policies/news_source_policy.current.json
REQUEST_TIMEOUT=10s
POLL_BLOCK=5s
BATCH_FLUSH_INTERVAL=1m
BATCH_MAX_ITEMS=100
SPOOL_DIR=./spool
FRONT_WINDOW_DURATION=2h
