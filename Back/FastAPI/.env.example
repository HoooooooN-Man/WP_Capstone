# Back/FastAPI/.env.example
# 이 파일을 .env 로 복사한 뒤 값 수정

# Capstone Data 루트 (기본: WP_Capstone 의 상위 폴더)
# CAPSTONE_ROOT=E:\Capstone Data

# DuckDB 경로 (시장/스코어/재무 — read-only)
# DUCKDB_PATH=E:\Capstone Data\WP_Capstone\Back\FastAPI\scores.duckdb

# 뉴스 적재 DuckDB (db 서버가 쓰기, 본 서버는 읽기) — DUCKDB_PATH 와 다른 파일이어야 함
# NEWS_DUCKDB_PATH=E:\Capstone Data\WP_Capstone\Back\db\db\news_data.duckdb

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1
REDIS_CACHE_TTL=60

# CORS 화이트리스트 — 콤마 구분, 운영 시 실제 도메인으로 교체
# 미설정 시 로컬 Vite 개발 서버(5173, 4173) 만 허용
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
