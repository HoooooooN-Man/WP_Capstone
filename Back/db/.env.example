# Back/db/.env.example
# 이 파일을 .env 로 복사한 뒤 실제 값으로 교체.
# 절대 .env 파일을 git 에 커밋하지 마세요.

# DuckDB — 시장 데이터(읽기 전용 공유). FastAPI ML 서버가 read-only 로 잡음.
DUCKDB_PATH=./project_data/db/market_data.duckdb

# 뉴스 적재 전용 DuckDB. /internal/ingest 가 쓰고, FastAPI 의 /news 가 읽음.
# 반드시 DUCKDB_PATH 와 다른 파일을 가리킬 것 (lock 충돌 방지).
NEWS_DUCKDB_PATH=./Back/db/db/news_data.duckdb

# PostgreSQL — 인증/유저/게시판 메타데이터
DB_USER=postgres
DB_PASSWORD=__CHANGE_ME__
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wp_capstone

# Redis — 세션·이메일 인증코드 저장 (queue Redis 와 별도 인스턴스)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_AUTH_DB=0
REDIS_DECODE_RESPONSES=True
REDIS_SOCKET_TIMEOUT=60
REDIS_CONNECT_TIMEOUT=10
REDIS_RETRY_ON_TIMEOUT=True

# SMTP (이메일 인증)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# CORS 화이트리스트 — 콤마 구분, 운영 시 실제 도메인으로 교체
# 미설정 시 로컬 Vite 개발 서버(5173, 4173) 만 허용
# CORS_ALLOW_ORIGINS=https://app.example.com,https://admin.example.com
